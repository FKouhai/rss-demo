---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Feeds from '../components/Feeds.tsx';
import { lookupService, locatorEndpoint } from '../lib/locator';

let initialData = [];
let error;

if (!locatorEndpoint()) {
  console.error('LOCATOR_URL environment variable is not set');
  error = 'LOCATOR_URL is not configured. Set it to the service locator URL.';
} else {
  const pollerFqdn = await lookupService('poller');
  if (!pollerFqdn) {
    console.error('poller is not registered in the service locator');
    error = 'poller is not registered in the service locator.';
  } else {
    try {
      const response = await fetch(`${pollerFqdn}/rss`, {
        headers: { 'Accept': 'application/json' },
      });
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      initialData = await response.json();
    } catch (e) {
      console.error(`Failed to fetch from rss-poller (${pollerFqdn}):`, e);
      error = 'RSS poller service is not running or returned an error.';
    }
  }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Latest Feeds</title>
    <style>
    #container {
      font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
      min-height: 100vh;
    }

    main {
      width: 100%;
    }

    #hero {
      width: 100%;
      padding: 16px;
    }

    @media (min-width: 1024px) {
      #container {
        padding-left: 13rem;
      }
    }
    </style>
</head>
<body>
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      const colorTheme = (typeof localStorage !== 'undefined' && localStorage.getItem('color-theme')) || 'slate';
      document.documentElement.setAttribute('data-theme', colorTheme);

      if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    </script>
    <div id="container">
      <div id="background" aria-hidden="true"><div class="blob blob-1"></div><div class="blob blob-2"></div></div>
      <Nav currentPage="feeds" />
      <main>
        <section id="hero">
          <Feeds data={initialData} error={error} client:load/>
        </section>
      </main>
    </div>
</body>
</html>
